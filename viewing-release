<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Viewing Release Form | The Adventures of Gaylord</title>
  <style>
    :root{
      --bg1:#6c5ce7;
      --bg2:#ff7675;
      --bg3:#fdcb6e;
      --bg4:#74b9ff;
      --bg5:#55efc4;
      --ink:#1e1834;
      --paper:#fffaf2;
      --card:rgba(255,255,255,.95);
      --accent:#ff2d55;
      --accent2:#00cec9;
      --good:#7bed9f;
      --bad:#ff8fab;
      --shadow:0 18px 50px rgba(30,24,52,.22);
      --radius:28px;
      --max:980px;
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      min-height:100vh;
      overflow-x:hidden;
      font-family:"Trebuchet MS","Comic Sans MS",Arial,sans-serif;
      color:var(--ink);
      background:
        radial-gradient(circle at 20% 20%, rgba(255,255,255,.55), transparent 20%),
        radial-gradient(circle at 80% 10%, rgba(255,255,255,.45), transparent 16%),
        radial-gradient(circle at 70% 80%, rgba(255,255,255,.3), transparent 18%),
        linear-gradient(135deg,var(--bg1),var(--bg2),var(--bg3),var(--bg4),var(--bg5));
      background-size:100% 100%,100% 100%,100% 100%,300% 300%;
      animation:bgShift 16s ease infinite;
    }

    @keyframes bgShift{
      0%{background-position:0% 0%,0% 0%,0% 0%,0% 50%}
      50%{background-position:0% 0%,0% 0%,0% 0%,100% 50%}
      100%{background-position:0% 0%,0% 0%,0% 0%,0% 50%}
    }

    .wrap{
      width:min(var(--max),calc(100% - 20px));
      margin:24px auto 40px;
    }

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      flex-wrap:wrap;
      margin-bottom:18px;
    }

    .brand,.back-btn{
      background:#fff;
      border:3px solid var(--ink);
      border-radius:999px;
      padding:10px 16px;
      font-weight:900;
      box-shadow:6px 6px 0 rgba(30,24,52,.14);
      text-decoration:none;
      color:var(--ink);
    }

    .brand{transform:rotate(-1deg);text-transform:uppercase}
    .back-btn:hover{transform:translateY(-2px) rotate(-1deg)}

    .hero,.panel{
      background:var(--card);
      border:4px solid rgba(30,24,52,.12);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
    }

    .hero{
      padding:28px;
      margin-bottom:18px;
      position:relative;
      overflow:hidden;
    }

    .hero::after{
      content:"VERY OFFICIAL CLIPBOARD ENERGY";
      position:absolute;
      top:16px;
      right:-30px;
      background:var(--accent);
      color:#fff;
      padding:10px 18px;
      border-radius:999px;
      border:3px solid rgba(255,255,255,.55);
      transform:rotate(10deg);
      font-weight:900;
      font-size:.82rem;
    }

    .eyebrow{
      display:inline-block;
      background:#fff;
      border:3px solid var(--ink);
      border-radius:999px;
      padding:8px 14px;
      font-weight:900;
      transform:rotate(-3deg);
      margin-bottom:14px;
      font-size:.82rem;
    }

    h1{
      margin:0;
      font-size:clamp(2.2rem,7vw,4.8rem);
      line-height:.95;
      text-transform:uppercase;
      text-shadow:3px 3px 0 rgba(255,255,255,.65);
    }

    .hero p,.panel p{
      line-height:1.7;
      font-size:1rem;
    }

    .panel{
      padding:24px;
    }

    .section-title{
      margin:0 0 10px;
      text-transform:uppercase;
      font-size:1.4rem;
    }

    .group{
      margin-top:18px;
      background:linear-gradient(180deg,#fff,#fffaf0);
      border:3px solid rgba(30,24,52,.10);
      border-radius:22px;
      padding:18px;
    }

    .group h3{
      margin:0 0 10px;
      text-transform:uppercase;
      font-size:1.02rem;
    }

    .hint{
      margin-top:10px;
      padding:10px 12px;
      border-radius:16px;
      background:linear-gradient(135deg,#fff,#ffeeb5);
      border:2px dashed rgba(30,24,52,.18);
      font-weight:900;
      line-height:1.5;
    }

    .options{
      display:grid;
      gap:10px;
      margin-top:10px;
    }

    label.option{
      display:flex;
      gap:10px;
      align-items:flex-start;
      background:#fff;
      border:2px solid rgba(30,24,52,.10);
      border-radius:16px;
      padding:12px;
      line-height:1.5;
      font-weight:700;
    }

    input[type="checkbox"], input[type="radio"]{
      margin-top:3px;
      transform:scale(1.2);
    }

    .form-grid{
      display:grid;
      gap:12px;
      margin-top:16px;
    }

    .two{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
    }

    input[type="text"], input[type="email"], input[type="tel"], textarea{
      width:100%;
      border:3px solid rgba(30,24,52,.14);
      border-radius:18px;
      padding:13px 14px;
      font:inherit;
      color:var(--ink);
      background:#fff;
      outline:none;
      box-shadow:0 8px 16px rgba(30,24,52,.05);
    }

    input:focus, textarea:focus{
      border-color:var(--accent2);
    }

    .btn-row{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:18px;
    }

    .btn{
      border:none;
      cursor:pointer;
      background:#fff;
      color:var(--ink);
      border:3px solid var(--ink);
      border-radius:999px;
      padding:12px 16px;
      font:inherit;
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.04em;
      box-shadow:0 8px 0 rgba(30,24,52,.12);
      transition:transform .16s ease;
    }

    .btn:hover{transform:translateY(-2px) rotate(-1deg)}
    .btn-primary{background:linear-gradient(135deg,#ffef66,#ff9f43)}

    .status{
      display:none;
      margin-top:14px;
      border:3px solid var(--ink);
      border-radius:18px;
      padding:12px 14px;
      font-weight:900;
      line-height:1.5;
    }

    .status.show{display:block}
    .status.success{background:linear-gradient(135deg,#d8ffd0,#7bed9f); color:#10301d}
    .status.error{background:linear-gradient(135deg,#ffd4de,#ff8fab); color:#4c1321}

    @media (max-width: 760px){
      .two{grid-template-columns:1fr}
      .hero::after{
        position:static;
        display:inline-block;
        margin-top:10px;
        transform:rotate(-2deg);
      }
      .hero,.panel{padding:18px}
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <div class="brand">The Adventures of Gaylord</div>
      <a class="back-btn" href="index.html">← Back to Main Site</a>
    </div>

    <section class="hero">
      <div class="eyebrow">A form with consequences</div>
      <h1>Viewing Release<br>Form</h1>
      <p>
        Welcome to the official form where the clipboard determines what parts of your mortal essence may be seen, heard, blurred, or otherwise launched into the chaos of production. Some answers may affect your role, because the paperwork has opinions.
      </p>
    </section>

    <section class="panel">
      <h2 class="section-title">Complete thy bureaucratic destiny</h2>
      <p>
        Fill this out honestly. The form is ridiculous, but the permissions are real.
      </p>

      <form id="releaseForm">
        <div class="group">
          <h3>Voice Consents</h3>
          <div class="options">
            <label class="option">
              <input type="checkbox" name="voiceConsents" value="I agree to have my voice shared with the SCHOOL project">
              <span>I agree to have my voice shared with the SCHOOL project</span>
            </label>
            <label class="option">
              <input type="checkbox" name="voiceConsents" value="I agree to have my voice shared PUBLICALLY">
              <span>I agree to have my voice shared PUBLICALLY</span>
            </label>
            <label class="option">
              <input type="checkbox" name="voiceConsents" value="I do not agree or consent to any of the above.">
              <span>I do not agree or consent to any of the above.</span>
            </label>
          </div>
          <div class="hint">Selection results may result in role changes, because the clipboard likes consequences.</div>
        </div>

        <div class="group">
          <h3>Face / Likeness Consents</h3>
          <div class="options">
            <label class="option">
              <input type="checkbox" name="faceConsents" value="I agree to show my face for the SCHOOL project">
              <span>I agree to show my face for the SCHOOL project</span>
            </label>
            <label class="option">
              <input type="checkbox" name="faceConsents" value="I agree to having my face shown PUBLICALLY">
              <span>I agree to having my face shown PUBLICALLY</span>
            </label>
            <label class="option">
              <input type="checkbox" name="faceConsents" value="I agree to have my face blurred PUBLICALLY">
              <span>I agree to have my face blurred PUBLICALLY</span>
            </label>
            <label class="option">
              <input type="checkbox" name="faceConsents" value="I do not agree or consent to any of the above.">
              <span>I do not agree or consent to any of the above.</span>
            </label>
          </div>
          <div class="hint">Some selections may result in role changes. Again: the clipboard has standards.</div>
        </div>

        <div class="group">
          <h3>Parental Approval</h3>
          <div class="options">
            <label class="option">
              <input type="radio" name="parentalApproval" value="I HAVE parental consent to participate in this production" required>
              <span>I HAVE parental consent to participate in this production</span>
            </label>
            <label class="option">
              <input type="radio" name="parentalApproval" value="I DO NOT HAVE parental consent to participate in this production" required>
              <span>I DO NOT HAVE parental consent to participate in this production</span>
            </label>
          </div>
        </div>

        <div class="group">
          <h3>Crew Verification</h3>
          <div class="form-grid">
            <div class="two">
              <input id="name" type="text" placeholder="Name" required>
              <input id="phone" type="tel" placeholder="Phone Number" required>
            </div>
            <input id="email" type="email" placeholder="Email" required>
          </div>
        </div>

        <div class="btn-row">
          <button class="btn btn-primary" id="submitBtn" type="submit">Submit Release Form</button>
        </div>

        <div id="statusMessage" class="status"></div>
      </form>
    </section>
  </div>

  <script type="module">
    import { db } from './firebase-config.js';
    import { collection, addDoc, serverTimestamp } from "https://www.gstatic.com/firebasejs/12.11.0/firebase-firestore.js";

    const form = document.getElementById("releaseForm");
    const submitBtn = document.getElementById("submitBtn");
    const statusMessage = document.getElementById("statusMessage");

    function getCheckedValues(name) {
      return Array.from(document.querySelectorAll(`input[name="${name}"]:checked`)).map(el => el.value);
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const voiceConsents = getCheckedValues("voiceConsents");
      const faceConsents = getCheckedValues("faceConsents");
      const parentalApproval = document.querySelector('input[name="parentalApproval"]:checked')?.value || "";

      if (!voiceConsents.length) {
        statusMessage.textContent = "You must select at least one voice consent option before the clipboard explodes emotionally.";
        statusMessage.className = "status show error";
        return;
      }

      if (!faceConsents.length) {
        statusMessage.textContent = "You must select at least one face / likeness consent option before the paperwork becomes offended.";
        statusMessage.className = "status show error";
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = "Submitting to the great bureaucratic void...";
      statusMessage.className = "status";
      statusMessage.textContent = "";

      try {
        await addDoc(collection(db, "viewingReleaseForms"), {
          name: document.getElementById("name").value.trim(),
          phone: document.getElementById("phone").value.trim(),
          email: document.getElementById("email").value.trim(),
          voiceConsents,
          faceConsents,
          parentalApproval,
          createdAt: serverTimestamp()
        });

        form.reset();
        statusMessage.textContent = "Release form submitted. The clipboard has consumed your answers and is considering your fate.";
        statusMessage.className = "status show success";
      } catch (error) {
        console.error(error);
        statusMessage.textContent = "Submission failed. Firestore is being dramatic again.";
        statusMessage.className = "status show error";
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Submit Release Form";
      }
    });
  </script>
</body>
</html>