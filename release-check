<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Release Authorization Check | The Adventures of Gaylord</title>
  <style>
    :root{
      --bg1:#6c5ce7;
      --bg2:#ff7675;
      --bg3:#fdcb6e;
      --bg4:#74b9ff;
      --bg5:#55efc4;
      --ink:#1e1834;
      --card:rgba(255,255,255,.95);
      --accent:#ff2d55;
      --shadow:0 18px 50px rgba(30,24,52,.22);
      --radius:28px;
      --max:1120px;
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      min-height:100vh;
      overflow-x:hidden;
      font-family:"Trebuchet MS","Comic Sans MS",Arial,sans-serif;
      color:var(--ink);
      background:
        radial-gradient(circle at 20% 20%, rgba(255,255,255,.55), transparent 20%),
        radial-gradient(circle at 80% 10%, rgba(255,255,255,.45), transparent 16%),
        radial-gradient(circle at 70% 80%, rgba(255,255,255,.3), transparent 18%),
        linear-gradient(135deg,var(--bg1),var(--bg2),var(--bg3),var(--bg4),var(--bg5));
      background-size:100% 100%,100% 100%,100% 100%,300% 300%;
      animation:bgShift 16s ease infinite;
    }

    @keyframes bgShift{
      0%{background-position:0% 0%,0% 0%,0% 0%,0% 50%}
      50%{background-position:0% 0%,0% 0%,0% 0%,100% 50%}
      100%{background-position:0% 0%,0% 0%,0% 0%,0% 50%}
    }

    .wrap{
      width:min(var(--max),calc(100% - 20px));
      margin:24px auto 40px;
    }

    .lock,.panel,.card{
      background:var(--card);
      border:4px solid rgba(30,24,52,.12);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
    }

    .lock{
      padding:28px;
      text-align:center;
    }

    .lock::after{
      content:"EXTREMELY SECRET PROBABLY";
      display:inline-block;
      margin-top:8px;
      background:var(--accent);
      color:#fff;
      padding:10px 18px;
      border-radius:999px;
      border:3px solid rgba(255,255,255,.55);
      font-weight:900;
      transform:rotate(-3deg);
      font-size:.82rem;
    }

    .eyebrow{
      display:inline-block;
      background:#fff;
      border:3px solid var(--ink);
      border-radius:999px;
      padding:8px 14px;
      font-weight:900;
      transform:rotate(-3deg);
      margin-bottom:14px;
      font-size:.82rem;
    }

    h1,h2,h3{margin-top:0;text-transform:uppercase}
    .panel{padding:24px;margin-top:18px}
    .grid{display:grid;gap:14px}
    .card{
      padding:16px;
      background:linear-gradient(180deg,#fff,#fffaf0);
    }

    input{
      width:100%;
      border:3px solid rgba(30,24,52,.14);
      border-radius:18px;
      padding:13px 14px;
      font:inherit;
      color:var(--ink);
      background:#fff;
      outline:none;
      box-shadow:0 8px 16px rgba(30,24,52,.05);
      margin-top:10px;
    }

    .btn-row{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:14px;
      justify-content:center;
    }

    .btn{
      border:none;
      cursor:pointer;
      background:#fff;
      color:var(--ink);
      border:3px solid var(--ink);
      border-radius:999px;
      padding:12px 16px;
      font:inherit;
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.04em;
      box-shadow:0 8px 0 rgba(30,24,52,.12);
      transition:transform .16s ease;
    }

    .btn:hover{transform:translateY(-2px) rotate(-1deg)}
    .btn-primary{background:linear-gradient(135deg,#ffef66,#ff9f43)}

    .status{
      display:none;
      margin-top:14px;
      border:3px solid var(--ink);
      border-radius:18px;
      padding:12px 14px;
      font-weight:900;
      line-height:1.5;
    }

    .status.show{display:block}
    .status.error{background:linear-gradient(135deg,#ffd4de,#ff8fab); color:#4c1321}

    .hidden{display:none !important}

    .meta{
      display:grid;
      gap:8px;
    }

    .meta div{
      background:rgba(255,255,255,.8);
      border:2px solid rgba(30,24,52,.08);
      border-radius:14px;
      padding:10px 12px;
      line-height:1.5;
    }

    .label{
      display:block;
      font-size:.75rem;
      font-weight:900;
      text-transform:uppercase;
      opacity:.72;
      margin-bottom:4px;
      letter-spacing:.05em;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="lock" id="lockBox">
      <div class="eyebrow">Manual URL nonsense</div>
      <h1>Authorization Check</h1>
      <p>
        You found the secret page by manually typing the URL like some kind of determined paperwork wizard. Enter the authorization code to view submitted release forms.
      </p>
      <input id="authCode" type="password" placeholder="Enter authorization code">
      <div class="btn-row">
        <button class="btn btn-primary" id="authBtn" type="button">Unlock The Clipboard Vault</button>
      </div>
      <div id="authStatus" class="status error"></div>
    </section>

    <section class="panel hidden" id="resultsPanel">
      <h2>Submitted Release Forms</h2>
      <div class="grid" id="resultsList"></div>
    </section>
  </div>

  <script type="module">
    import { db } from './firebase-config.js';
    import { collection, getDocs, query, orderBy } from "https://www.gstatic.com/firebasejs/12.11.0/firebase-firestore.js";

    const AUTH_CODE = "Authorizations";

    const authCode = document.getElementById("authCode");
    const authBtn = document.getElementById("authBtn");
    const authStatus = document.getElementById("authStatus");
    const lockBox = document.getElementById("lockBox");
    const resultsPanel = document.getElementById("resultsPanel");
    const resultsList = document.getElementById("resultsList");

    function escapeHtml(text) {
      return String(text ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    async function loadResults() {
      const snap = await getDocs(query(collection(db, "viewingReleaseForms"), orderBy("createdAt", "desc")));

      if (!snap.size) {
        resultsList.innerHTML = `<div class="card"><h3>No forms yet</h3><p>The clipboard is waiting patiently for more human compliance.</p></div>`;
        return;
      }

      resultsList.innerHTML = snap.docs.map(d => {
        const x = d.data();
        return `
          <div class="card">
            <h3>${escapeHtml(x.name || "Unnamed person")}</h3>
            <div class="meta">
              <div><span class="label">Phone</span>${escapeHtml(x.phone || "")}</div>
              <div><span class="label">Email</span>${escapeHtml(x.email || "")}</div>
              <div><span class="label">Voice Consents</span>${escapeHtml((x.voiceConsents || []).join(", "))}</div>
              <div><span class="label">Face / Likeness Consents</span>${escapeHtml((x.faceConsents || []).join(", "))}</div>
              <div><span class="label">Parental Approval</span>${escapeHtml(x.parentalApproval || "")}</div>
            </div>
          </div>
        `;
      }).join("");
    }

    authBtn.addEventListener("click", async () => {
      if (authCode.value !== AUTH_CODE) {
        authStatus.textContent = "Incorrect code. The clipboard has become suspicious and slightly smug.";
        authStatus.className = "status error show";
        return;
      }

      authStatus.classList.remove("show");
      lockBox.classList.add("hidden");
      resultsPanel.classList.remove("hidden");

      try {
        await loadResults();
      } catch (error) {
        console.error(error);
        resultsList.innerHTML = `<div class="card"><h3>Load failed</h3><p>Firestore is being dramatic again.</p></div>`;
      }
    });

    authCode.addEventListener("keydown", (e) => {
      if (e.key === "Enter") authBtn.click();
    });
  </script>
</body>
</html>